# Required
DARWIN_WALLET_PASSPHRASE=your-secure-passphrase-min-12-chars

# Telegram notifications (optional but recommended)
TELEGRAM_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Polymarket API (optional, for prediction strategy)
POLYMARKET_API_KEY=your-polymarket-clob-key

# Logging
LOG_LEVEL=info
